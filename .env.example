# Copy to .env and fill in. The harness reads everything from env (python-dotenv).

# ── Database (required) ───────────────────────────────────────────────────────
# PostgreSQL. On Railway this is injected automatically by the Postgres addon.
DATABASE_URL=

# ── Telegram (optional — enables /edge + /diagnose) ───────────────────────────
TG_TOKEN=
TG_CHAT_ID=

# ── Mode ──────────────────────────────────────────────────────────────────────
PAPER_TRADING=true

# ── Coin universe ─────────────────────────────────────────────────────────────
# Core is always scanned; DYNAMIC_DISCOVERY tops up to MAX_PAIRS with liquid,
# established, non-blacklisted pairs (keeps fresh pump listings out).
WATCHLIST=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,ADA/USDT,AVAX/USDT,LINK/USDT,DOT/USDT,LTC/USDT,BCH/USDT,NEAR/USDT,UNI/USDT,ATOM/USDT,APT/USDT,OP/USDT,ARB/USDT,SUI/USDT,TIA/USDT
DYNAMIC_DISCOVERY=true
MAX_PAIRS=35
MIN_VOLUME_USDT=10000000
MIN_PAIR_AGE_DAYS=300
# PAIR_BLACKLIST=LAB/USDT,LUNC/USDT

# ── Timeframes fed to generate_signal ─────────────────────────────────────────
ENTRY_TF=15m
CONFIRM_TF=1h
TREND_TF=4h
BIAS_TF=1d

# ── Loop + analytics segmentation ─────────────────────────────────────────────
SCAN_INTERVAL_SEC=900
RUN_TAG=v1
